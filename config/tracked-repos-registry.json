{
  "schema_version": "plx-tracked-repos/v1",
  "description": "Repos that must follow PLX_MC governance (config/governance-contract.yaml + COLLABORATOR-SOP). MC visibility is optional per tier.",
  "governance_contract": {
    "repo": "taylorvalton/PLX_MC",
    "path": "config/governance-contract.yaml",
    "surfaces_generator": "scripts/generate-governance-surfaces.py",
    "compliance_gate_generator": "scripts/generate-compliance-gate.py"
  },
  "collaborator_sop": {
    "repo": "taylorvalton/PLX_MC",
    "path": "docs/COLLABORATOR-SOP.md"
  },
  "onboarding_runbook": "docs/runbooks/REPO-ONBOARDING.md",
