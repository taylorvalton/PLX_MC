      "release_branch": null,
      "compliance_mode": "hard",
      "quality_ledger": {
        "enabled": true,
        "glob": "docs/plx-mc/quality-ledger/*.artifacts.json",
        "evidence_dir": "docs/plx-mc/quality-ledger/evidence"
