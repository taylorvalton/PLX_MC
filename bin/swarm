#!/usr/bin/env bash
# Wrapper for the agentic-swarm CLI (cloned to ./.swarm by .cursor/environment.json).
# Clears DATABASE_URL so the swarm uses in-memory checkpointing
# (avoids needing a Postgres driver/connection locally).

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
VENV="$SCRIPT_DIR/../.swarm/.venv"

if [ ! -d "$VENV" ]; then
    echo "Error: swarm venv not found at $VENV" >&2
    echo "Run the .cursor/environment.json install, or:" >&2
    echo "  git clone https://github.com/taylorvalton/agentic-swarm.git .swarm \\" >&2
    echo "    && python3 -m venv .swarm/.venv \\" >&2
    echo "    && .swarm/.venv/bin/pip install -e ./.swarm" >&2
    exit 1
fi

DATABASE_URL="" exec "$VENV/bin/swarm" "$@"
